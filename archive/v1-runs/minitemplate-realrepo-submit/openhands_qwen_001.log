[36m│[0m                 self.tokens.append(Token(Token.VAR_END, '', self.pos))      [36m│[0m
[36m│[0m                 self.pos += 3                                               [36m│[0m
[36m│[0m                 if self.pos < len(self.source):                             [36m│[0m
[36m│[0m                     start = self.pos                                        [36m│[0m
[36m│[0m                     while self.pos < len(self.source) and                   [36m│[0m
[36m│[0m self.source[self.pos] in ' \t\n':                                           [36m│[0m
[36m│[0m                         self.pos += 1                                       [36m│[0m
[36m│[0m             # Check for {%                                                  [36m│[0m
[36m│[0m             elif self.source[self.pos:self.pos+2] == '{%':                  [36m│[0m
[36m│[0m                 self.tokens.append(Token(Token.BLOCK_START, '', self.pos))  [36m│[0m
[36m│[0m                 self.pos += 2                                               [36m│[0m
[36m│[0m             # Check for %}                                                  [36m│[0m
[36m│[0m             elif self.source[self.pos:self.pos+2] == '%}':                  [36m│[0m
[36m│[0m                 self.tokens.append(Token(Token.BLOCK_END, '', self.pos))    [36m│[0m
[36m│[0m                 self.pos += 2                                               [36m│[0m
[36m│[0m             # Check for {{                                                  [36m│[0m
