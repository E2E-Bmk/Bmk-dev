[36m│[0m                 next_pos = self.pos                                         [36m│[0m
[36m│[0m                 while next_pos < len(self.source):                          [36m│[0m
[36m│[0m                     if self.source[next_pos:next_pos+2] in ('{%', '{{',     [36m│[0m
[36m│[0m '%}', '}}') or self.source[next_pos:next_pos+3] in ('{%-', '{{-', '-%}',    [36m│[0m
[36m│[0m '-}}'):                                                                     [36m│[0m
