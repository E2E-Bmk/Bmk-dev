[36m│[0m                 self.tokens.append(Token(Token.VAR_START, '', self.pos))    [36m│[0m
[36m│[0m                 self.pos += 2                                               [36m│[0m
[36m│[0m             # Check for }}                                                  [36m│[0m
[36m│[0m             elif self.source[self.pos:self.pos+2] == '}}':                  [36m│[0m
[36m│[0m                 self.tokens.append(Token(Token.VAR_END, '', self.pos))      [36m│[0m
[36m│[0m                 self.pos += 2                                               [36m│[0m
[36m│[0m             else:                                                           [36m│[0m
